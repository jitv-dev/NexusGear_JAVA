<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.xml — Descriptor de despliegue de la aplicación web.
  Lección 6: Despliegue en Apache Tomcat 10.x
  Se configura correctamente para generar el archivo .WAR
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

  <!-- ===== Metadatos de la aplicación ===== -->
  <display-name>NexusGear - Tienda Gaming</display-name>
  <description>
    Proyecto Módulo 5 — Desarrollo de aplicaciones web dinámicas Java EE.
    Tienda de insumos gamer con patrón MVC, Servlets, JSP, JDBC y DAO.
  </description>

  <!-- ===== Configuración de sesión / 30 minutos/ ===== -->
  <session-config>
    <session-timeout>30</session-timeout>  
  </session-config>

  <!-- ===== Página de bienvenida ===== -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- ===== Manejo de errores ===== -->
  <error-page>
    <error-code>404</error-code>
    <location>/index.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/index.jsp</location>
  </error-page>

  <!--
    NOTA: Con Jakarta EE 9+ y anotaciones @WebServlet,
    NO es necesario declarar los servlets aquí manualmente.
    El contenedor los detecta automáticamente.

    Si usas Tomcat 9 (javax.servlet), reemplaza los imports
    en los servlets de jakarta.servlet por javax.servlet.
  -->

</web-app>
